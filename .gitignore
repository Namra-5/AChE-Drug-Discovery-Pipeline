# ============================================================
# AChE-Drug-Discovery-Pipeline — .gitignore
# ============================================================


# ------------------------------------------------------------
# R SPECIFIC
# ------------------------------------------------------------

# History & session data
.Rhistory
.Rapp.history
.RData
.Ruserdata

# R project files (each member uses their own local .Rproj)
*.Rproj
.Rproj.user/

# R package build artifacts
*.tar.gz
*.o
*.so
*.dll
src/*.o
src/*.so

# knitr / rmarkdown caches and temp files
*_cache/
/cache/
*.utf8.md
*.knit.md
*_files/

# Packrat / renv (dependency managers)
packrat/lib*/
packrat/src/
renv/library/
renv/local/
renv/python/
renv/staging/
.Rprofile          # only if auto-generated by renv


# ------------------------------------------------------------
# PYTHON SPECIFIC (Task 7 — Molecular Docking)
# ------------------------------------------------------------

__pycache__/
*.py[cod]
*$py.class
*.egg
*.egg-info/
dist/
build/
.eggs/
.env
.venv
env/
venv/
ENV/
.Python
pip-log.txt
pip-delete-this-directory.txt
*.pyo


# ------------------------------------------------------------
# LARGE CHEMINFORMATICS / BIOINFORMATICS FILES
# These will BREAK GitHub (100 MB file limit)
# Store locally. Upload only summary CSVs / PNGs instead.
# ------------------------------------------------------------

# Structure & library files
*.sdf
*.mol
*.mol2
*.pdb
*.pdbqt
*.mae
*.maegz
*.cif

# Docking outputs (trajectories, all-pose folders)
all_poses/
docking_runs/
*.dlg
*.gpf
*.dpf
*.glg
*.trg
*_out.pdbqt

# Large descriptor / fingerprint matrices
# (keep only the final trimmed CSV)
*_full_descriptors.csv
*_raw_fingerprints.csv

# Raw bulk downloads (PubChem, ChEMBL, ZINC)
*chembl_download*
*pubchem_bulk*
zinc_*.sdf
zinc_*.csv.gz
*.csv.gz
*.tsv.gz

# Compressed archives
*.zip
*.tar
*.tar.gz
*.tar.bz2
*.rar
*.7z

# Large image / video outputs from visualization tools
*.tiff
*.tif
*.bmp
*.mp4
*.avi


# ------------------------------------------------------------
# OS & EDITOR GARBAGE
# ------------------------------------------------------------

# macOS
.DS_Store
.AppleDouble
.LSOverride
._*
.Spotlight-V100
.Trashes

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# Linux
*~

# VS Code
.vscode/

# JetBrains IDEs
.idea/

# Jupyter (if anyone uses it)
.ipynb_checkpoints/
*.ipynb


# ------------------------------------------------------------
# MISC
# ------------------------------------------------------------

# Log files
*.log
*.out

# Temp files
tmp/
temp/
*.tmp
*.bak
*.swp
