# ============================================================
# AChE-Drug-Discovery-Pipeline — .gitignore
# ============================================================

# ── R ───────────────────────────────────────────────────────
.Rhistory
.RData
.Rproj.user/
*.Rproj
*.Rcheck/
*_cache/
/cache/
docs/

# ── Python ──────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/
.env
.venv/
env/
venv/
*.ipynb_checkpoints/

# ── Large Binary / Intermediate Files ───────────────────────
# Molecular files that blow past GitHub's 100 MB limit
*.sdf
*.mol2
*.mol
# Raw docking output (keep summary CSVs and PNGs instead)
all_poses/
*_poses/
# AlphaFold environment archives (huge, not needed in repo)
*.a3m
*.tar.gz
*.tar.bz2
*.tar.xz
# NumPy binary arrays (large, regenerate from scripts)
*.npy
*.npz
# Serialised model objects
*.pkl
*.pickle
*.joblib
*.h5
*.hdf5
*.pt
*.pth
# Compiled / cached binaries
*.so
*.dll
*.dylib

# ── Docking-Specific ────────────────────────────────────────
# Raw AutoDock Vina ligand conformations — keep *_log.txt, keep summary CSVs
*_output.pdbqt
# Large receptor files (only keep the prepared one you actually use)
*.pdbqt

# ── Data Files Too Large for GitHub ─────────────────────────
# Raw PubChem / ChEMBL bulk exports
*_bulk_*.csv
*_raw_download*

# ── OS / Editor Junk ────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini
*.swp
*.swo
*~
.idea/
.vscode/
*.code-workspace

# ── Logs ────────────────────────────────────────────────────
*.log
# Exception: keep Vina docking logs (they are small and useful)
!ligand*_log.txt
!vina_*.log

# ── What IS tracked (override exceptions) ───────────────────
!*.R
!*.Rmd
!*.py
!*.sh
!*.csv
!*.png
!*.jpg
!*.jpeg
!*.pdf
!*.txt
!*.html
!*.smi
!*.json
!*.bibtex
!*.pdb
!README.md
!LICENSE
!.gitignore
!*.gitkeep
